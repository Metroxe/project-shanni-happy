# python
studio/.venv/
studio/.venv-music/
__pycache__/
*.pyc

# node
node_modules/

# assembled static site (build artifact; CI/deploy regenerate it from studio/)
_site/

# playwright smoke-test output
test-results/

# machine-specific chrome path cache for playwright capture
studio/.exec

# build stamp — written by the Pages deploy, not committed (local dev = "dev")
studio/build.json

# secrets — NEVER commit
*.gkey
.gkey
*.env
.secrets*

# os
.DS_Store

# large intermediate render frames (regenerated on demand)
studio/out/anim/
studio/out/walk/
studio/out/joy/
studio/out/paper/

# prototype/comparison renders + image-to-3D GLBs (regenerable, not used by the game)
studio/out/3d/
studio/out/hero/
studio/out/tex/

# env-QA screenshot battery (regenerated by studio/qa_shots.mjs each run)
studio/out/qa/

# per-worktree dev server config (generated by .claude/serve.sh)
.claude/launch.json

# QA gate stamp — written by studio/qa_audit.mjs on a clean pass, read by the Stop
# hook (.claude/hooks/qa-gate.mjs). Per-worktree local state, never committed.
.claude/.qa-stamp

# local A/B audition tool for music candidates (references git-ignored raw/ loops)
studio/music-audition.html
