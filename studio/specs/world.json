    {
      "id": "q_hamsters", "name": "Hamster Roundup", "giver": "Adrian",
      "summary": "Five of Adrian's pet-shop hamsters escaped their cage and scattered across town.",
      "steps": [
        { "desc": "Round up all 5 runaway hamsters.", "goal": { "type": "collect", "kind": "hamster", "count": 5 } },
