  "quests": [
    {
      "id": "q_hamsters", "name": "Hamster Roundup", "giver": "Adrian",
      "summary": "Five of Adrian's pet-shop hamsters escaped their cage and scattered across town.",
      "steps": [
        { "desc": "Round up all 5 runaway hamsters.", "goal": { "type": "collect", "kind": "hamster", "count": 5 } },
        { "desc": "Bring the hamsters home to Adrian.", "goal": { "type": "talk", "npc": "Adrian" } }
      ]
    }
  ],

  "npcs": [
    {
      "name": "Chrees",
      "tex": "out/chrees-down-paper.png",
      "poses": { "down": "out/chrees-down-paper.png", "curl": "out/chrees-curl-paper.png" },
      "rep": { "seq": ["down", "curl"], "beat": 0.72, "sfxOn": "curl" },
      "x": -16.8, "z": -20, "h": 2.4,
      "dialogue": {
        "start": "g1",
        "nodes": {
          "g1":   { "text": "Hey! You're the one bouncing around the plaza, huh?", "next": "g2" },
          "g2":   { "text": "Name's Chrees. I get my reps in down this street — good shade between the towers.", "next": "g3" },
          "g3":   { "speaker": "Shen", "text": "Nice to meet you, Chrees!", "next": "menu" },
          "menu": { "text": "So — what's on your mind?", "choices": [
            { "label": "Got any training tips?",     "next": "t1" },
            { "label": "What's good around here?",    "next": "area" },
            { "label": "I'd better get going.",       "next": "bye" }
          ] },
          "t1":   { "text": "Easy — stay light on your feet. Keep moving and the bounce takes care of itself.", "next": "t2" },
          "t2":   { "text": "Hop everywhere you go, champ. Your legs remember it better than your head does.", "next": "menu" },
          "area": { "text": "Quiet little block, but it grows on you. Adrian runs the pet shop just down past the stairs — good soul, always could use a hand.", "next": "menu" },
          "bye":  { "text": "Catch you later. Stay bouncy! ✿" }
        }
      }
    },
    {
      "name": "Adrian",
      "tex": "out/adrian-paper.png",
      "x": -10, "z": 0.8, "h": 2.3,
      "quest": "q_hamsters",
      "dialogue": {
        "start": "intro",
        "nodes": {
          "intro":  { "text": "Oh! Hello there. I'm Adrian — I mind the little pet shop just here.", "next": "intro2" },
          "intro2": { "text": "I'm in a bit of a flap, honestly. I left the hamster cage open and... well.", "next": "intro3" },
          "intro3": { "text": "Five of my hamsters slipped out and scattered all over town. I can't chase them myself.", "next": "offer" },
          "offer":  { "text": "You're so quick on your feet — would you help me round up my five little ones?", "choices": [
            { "label": "Of course I'll help!", "next": "accept" },
            { "label": "Where might they be?", "next": "hint" },
            { "label": "Maybe later.",         "next": "later" }
          ] },
          "accept": { "text": "Oh, thank you, truly! Bring each one back to me — gently, they're shy little things.", "action": "start:q_hamsters", "next": "hint" },
          "hint":   { "text": "They love warm corners — try the plaza, along the main street, and down in the park past the steps. Listen for tiny squeaks!" },
          "later":  { "text": "That's alright. I'll be right here if you change your mind." },
          "progress": { "text": "Any luck with my little escapees? They're awfully quick, I know.", "choices": [
            { "label": "Still looking!", "next": "progAck" },
            { "label": "Where again?",   "next": "hint" }
          ] },
          "progAck": { "text": "Thank you for trying. Every one you bring back is a weight off my heart." },
          "ready":   { "text": "You found them ALL? Oh — come here, you fuzzy little troublemakers!", "next": "ready2" },
          "ready2":  { "speaker": "Shen", "text": "Every last hamster, safe and sound!", "next": "ready3" },
          "ready3":  { "text": "I can't thank you enough. The shop feels whole again — you're always welcome here. ✿" },
          "done":    { "text": "There you are! The hamsters keep squeaking for you. Thank you again, friend. ✿" }
        }
      }
    }
  ]
}
