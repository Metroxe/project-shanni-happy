            { "label": "Seen any flowers around?",    "next": "f1" },
            { "label": "Just saying hi.",             "next": "h1" },
            { "label": "I'd better get going.",       "next": "bye" }
          ] },
          "t1":   { "text": "Easy — jump for joy after every win. Celebrating IS the rep.", "next": "t2" },
          "t2":   { "text": "Squash down low, then launch. Your whole body remembers the bounce.", "next": "menu" },
          "f1":   { "text": "Saw a pink one back up the stairs, and one down each road. Go get 'em, champ!", "next": "menu" },
          "h1":   { "text": "Hi yourself! Always good to see a friendly face down here.", "next": "menu" },
          "bye":  { "text": "Catch you later. Stay bouncy! ✿" }
        }
      }
    }
