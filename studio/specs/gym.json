  "npcs": [
    {
      "name": "Chrees",
      "tex": "out/chrees-down-paper.png",
      "poses": { "down": "out/chrees-down-paper.png", "curl": "out/chrees-curl-paper.png" },
      "rep": { "seq": ["down", "curl"], "beat": 0.72, "sfxOn": "curl" },
      "x": 1.8, "z": 0.6, "h": 2.4,
      "dialogue": {
        "start": "g1",
        "nodes": {
          "g1":   { "text": "Hey, look who bounced in! Welcome to my gym, champ.", "next": "g2" },
          "g2":   { "text": "Name's Chrees. Used to train out on the street — built this little place so I'd have a roof when it rained.", "next": "g3" },
          "g3":   { "speaker": "Shen", "text": "It's great in here, Chrees!", "next": "menu" },
          "menu": { "text": "So — what're you after today?", "choices": [
            { "label": "Got any training tips?",     "next": "t1" },
            { "label": "What's all this gear?",       "next": "gear" },
            { "label": "What's good around here?",    "next": "area" },
            { "label": "I'd better get going.",       "next": "bye" }
          ] },
          "t1":   { "text": "Easy — stay light on your feet. Keep moving and the bounce takes care of itself.", "next": "t2" },
          "t2":   { "text": "Hop everywhere you go. Your legs remember it better than your head does.", "next": "menu" },
          "gear": { "text": "Treadmills by the wall, a squat rack in the middle, benches and dumbbells over there. Front desk's just for show — it's free, ha.", "next": "menu" },
          "area": { "text": "Quiet little block, but it grows on you. Adrian runs the pet shop just down past the stairs — good soul, always could use a hand.", "next": "menu" },
          "bye":  { "text": "Catch you later. Stay bouncy! ✿" }
        }
      }
    }
  ],

